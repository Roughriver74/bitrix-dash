# Битрикс24 Webhook URL
# Формат: https://ваш-домен.bitrix24.ru/rest/ID/токен/
# Важно: URL должен заканчиваться на /

BITRIX_WEBHOOK_URL=https://crmwest.ru/rest/156/0at4n9lo2rik3a3j/
# Название отдела в Битрикс24
BITRIX_DEPARTMENT_NAME=IT отдел

# Загрузка Scrum весов (storyPoints) - по умолчанию отключено для ускорения
# Веса загружаются только для задач из проекта с ID=52
# Включите, если нужны веса: LOAD_SCRUM_WEIGHTS=true
# LOAD_SCRUM_WEIGHTS=true

# Upstash Redis (optional, for production caching)
# UPSTASH_REDIS_REST_URL=your-upstash-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token